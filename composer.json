{
    "name": "brian/reservation-system",
    "description": "Simulating restaurant reservation system with PHP/Laravel",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Reservations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Brian Yang",
            "email": "brianjsyang@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ramsey/uuid": "^4.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
